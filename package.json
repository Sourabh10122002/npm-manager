{
  "name": "npm-manager-v2",
  "displayName": "NPM Manager - Visual Package Explorer",
  "description": "Visual NPM package manager for VS Code.",
  "version": "0.1.3",
  "publisher": "sourabhr10122002",
  "repository": {
    "type": "git",
    "url": "https://github.com/sourabh10122002/npm-manager"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "npm",
    "package",
    "manager",
    "explorer",
    "node",
    "visualization"
  ],
  "license": "MIT",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "npm-manager-sidebar",
          "title": "NPM Manager",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "npm-manager-sidebar": [
        {
          "type": "webview",
          "id": "npm-manager-view",
          "name": "Manage Packages",
          "icon": "resources/sidebar-icon.svg",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "npm-manager.open",
        "title": "Open NPM Manager",
        "category": "NPM Manager"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "build": "npm run compile",
    "package": "vsce package",
    "publish:vscode": "vsce publish",
    "publish:openvsx": "ovsx publish",
    "publish": "npm run publish:vscode && npm run publish:openvsx"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.14.0"
  }
}